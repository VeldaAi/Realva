# ─────────────────────────────────────────────
# Realva — environment template
# Copy to .env and fill in real values.
# ─────────────────────────────────────────────

# App
NODE_ENV=production
APP_URL=https://realva.velda.ai
NEXT_PUBLIC_APP_URL=https://realva.velda.ai
PORT=3001

# ─── Database (Postgres) ──────────────────────
# Hostname "postgres" is the docker-compose service name
POSTGRES_USER=realva
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=realva
DATABASE_URL=postgresql://realva:change-me-strong-password@postgres:5432/realva?schema=public

# ─── Redis + BullMQ ───────────────────────────
REDIS_URL=redis://redis:6379

# ─── MinIO (S3-compatible storage) ────────────
MINIO_ROOT_USER=realva-admin
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=realva-documents
MINIO_PUBLIC_URL=https://realva.velda.ai/files

# ─── Better-Auth ──────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=https://realva.velda.ai

# ─── DeepSeek (LLM) ───────────────────────────
# Powers every AI feature. Get a free key at https://platform.deepseek.com/
# (~$5 free credits on signup). You can paste this later via /admin/apis
# instead of editing .env.
DEEPSEEK_API_KEY=sk-...

# ─── Stripe ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_TEAM=price_...

# ─── Resend (transactional email) ─────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notifications@velda.ai

# ─── RentCast (comps / property data) ─────────
RENTCAST_API_KEY=

# ─── Census + GreatSchools (Neighborhood Reports) ─
CENSUS_API_KEY=
GREATSCHOOLS_API_KEY=

# ─── Rate limiting ────────────────────────────
RATE_LIMIT_PER_HOUR=100

# ─── Admins ───────────────────────────────────
# Any email listed here ALSO gets admin access regardless of user.role
# (comma-separated). Useful as a break-glass if a role gets flipped.
ADMIN_EMAILS=jason@velda.ai
# The single admin created by `npm run prisma:seed`.
# Change the password immediately after first login.
ADMIN_SEED_EMAIL=jason@velda.ai
ADMIN_SEED_PASSWORD=password123!

# ─── API key encryption ───────────────────────
# If set (32 random bytes, base64), every API key stored in the Settings
# table via /admin/apis is encrypted at rest. Generate with:
#   openssl rand -base64 32
SETTING_ENCRYPTION_KEY=
